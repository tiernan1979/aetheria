; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Aetheria"
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/bg_color=Color(0.02, 0.01, 0.04, 1)
boot_splash/show_image=false
config/icon="res://assets/placeholder/icon.png"

[autoload]

ItemDB="*res://scripts/ItemDatabase.gd"
CraftDB="*res://scripts/CraftingDatabase.gd"
SaveSystem="*res://scripts/SaveSystem.gd"
MountSystem="*res://scripts/MountSystem.gd"
AudioManager="*res://scripts/AudioManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

